{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "snapshot": true,
  "default_agent": "analyst",
  "model": "google/gemini-2.5-flash",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "qwen/qwen3-coder:free": {}
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      },
      "models": {
        "gemini-2.5-flash": {},
        "gemini-2.5-flash-lite": {}
      }
    }
  },
  "permission": {
    "edit": "deny",
    "write": "deny",
    "patch": "deny",
    "bash": { "*": "ask" },
    "websearch": "allow",
    "webfetch": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "skill": { "*": "deny" }
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
      "headers": {
        "x-api-key": "${EXA_API_KEY}"
      }
    }
  }
}
